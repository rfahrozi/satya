# ============================================================
# SATYA — Environment Variables Template
# ============================================================
# PETUNJUK PENGGUNAAN:
#   1. Salin file ini: cp .env.example .env
#   2. Isi SEMUA nilai yang bertanda <WAJIB_DIISI>
#   3. JANGAN pernah commit file .env ke Git
#   4. Generate JWT_SECRET dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================

# --- Database (PostgreSQL) ---
DB_HOST=db
DB_PORT=5432
DB_USER=satya_admin
DB_PASSWORD=<WAJIB_DIISI: gunakan password acak minimal 20 karakter>
DB_NAME=satya_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO (S3-Compatible Object Storage) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=<WAJIB_DIISI: username MinIO>
MINIO_SECRET_KEY=<WAJIB_DIISI: password MinIO acak minimal 20 karakter>
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# --- Aplikasi ---
NODE_ENV=production
PORT=3000
BASE_PATH=/satya
BASE_URL=https://devapps.pt-kepri.go.id/satya

# JWT Secret — WAJIB diganti sebelum production!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<WAJIB_DIISI: string acak 128 karakter hex>

# CORS — daftar origin yang diizinkan, pisahkan dengan koma (tanpa spasi)
# Contoh: https://satya.pt-kepri.go.id,https://www.pt-kepri.go.id
ALLOWED_ORIGINS=http://localhost:3000

FRONTEND_URL=http://localhost:3000

# --- Konfigurasi Email (SMTP) ---
# Gunakan App Password (bukan password akun utama) jika pakai Gmail/Outlook
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<WAJIB_DIISI: alamat email pengirim>
SMTP_PASS=<WAJIB_DIISI: App Password SMTP — bukan password login>
EMAIL_FROM_NAME=SATYA - Monitoring PT

# Untuk environment development: ubah NODE_ENV=development

# --- Konfigurasi Internal Monitoring PT ---
PT_INTERNAL_MONITORING_ENABLED=false
PT_INTERNAL_MONITORING_EMAIL_ENABLED=false
PT_INTERNAL_MONITORING_FOLLOW_UP_ENABLED=false

# Kalender bisnis untuk perhitungan hari kerja
BUSINESS_CALENDAR_DEFAULT_CODE=ID_NATIONAL

# Batas ukuran upload file evidence (default: 10MB = 10485760 bytes)
MONITORING_UPLOAD_MAX_BYTES=10485760

# TTL Presigned URL untuk download file dari MinIO (default: 1 jam = 3600 detik)
MONITORING_PRESIGNED_URL_TTL_SECONDS=3600

# Jumlah retry notifikasi gagal
MONITORING_NOTIFICATION_RETRY_LIMIT=3

# --- Opsional: Seed otomatis saat container pertama kali berjalan ---
# Aktifkan HANYA di environment development/UAT, JANGAN di production
# SEED_ON_STARTUP=false

# --- APM & Tracing ---
SENTRY_DSN=<WAJIB_DIISI: masukkan DSN Sentry di sini atau kosongkan untuk mematikan>
